        "large": "/drivers/hagelschutz/assets/images/large.png"
      },
      "pair": [
        {
          "id": "start"
        }
      ],
      "settings": [
        {
          "type": "group",
          "label": {
            "en": "API Configuration",
            "de": "API-Konfiguration",
            "fr": "Configuration API"
          },
          "children": [
            {
              "id": "device_id",
              "type": "text",
              "label": {
                "en": "Device ID (Serial Number)",
                "de": "Geräte-ID (Seriennummer / MAC-Adresse)",
                "fr": "ID de l'appareil (numéro de série)"
              },
              "hint": {
                "en": "12-character serial number (MAC address of your Signalbox), provided after registration at meteo.netitservices.com",
                "de": "12-stellige Seriennummer (MAC-Adresse der Signalbox), erhalten nach Registrierung auf meteo.netitservices.com",
                "fr": "Numéro de série à 12 caractères (adresse MAC de votre Signalbox), fourni après l'inscription sur meteo.netitservices.com"
              },
              "value": ""
            },
            {
              "id": "hwtype_id",
              "type": "number",
              "label": {
                "en": "Hardware Type ID (hwtypeId)",
                "de": "Hardware-Typ-ID (hwtypeId)",
                "fr": "ID type matériel (hwtypeId)"
              },
              "hint": {
                "en": "Integer device type identifier provided at registration (see your registration confirmation).",
                "de": "Ganzzahliger Gerätetyp-Identifikator, erhalten bei der Registrierung (siehe Registrierungsbestätigung).",
                "fr": "Identifiant entier du type d'appareil fourni lors de l'inscription (voir votre confirmation d'inscription)."
              },
              "value": 1,
              "min": 1,
              "max": 9999,
              "step": 1
            }
          ]
        },
        {
          "type": "group",
          "label": {
            "en": "Polling",
            "de": "Abfrage",
            "fr": "Interrogation"
          },
          "children": [
            {
              "id": "poll_interval",
              "type": "number",
              "label": {
                "en": "Poll interval (seconds)",
                "de": "Abfrageintervall (Sekunden)",
                "fr": "Intervalle d'interrogation (secondes)"
              },
              "hint": {
                "en": "How often the API is queried. The API specification requires a minimum of 120 seconds. To test immediately, use the Flow action \"Check hail status now\".",
                "de": "Wie oft die API abgefragt wird. Minimum 120 Sekunden laut API-Spezifikation. Zum sofortigen Testen die Flow-Aktion \"Hagelstatus jetzt prüfen\" verwenden.",
                "fr": "Fréquence d'interrogation de l'API. La spécification API exige un minimum de 120 secondes. Pour tester immédiatement, utilisez l'action Flow «Vérifier le statut grêle maintenant»."
              },
              "value": 120,
              "min": 120,
              "max": 3600,
              "step": 10
            }
          ]
        }
      ],
      "id": "hagelschutz"
    }
