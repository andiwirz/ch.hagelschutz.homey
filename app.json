{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "ch.hagelschutz.homey",
  "version": "1.0.0",
  "compatibility": ">=5.0.0",
  "sdk": 3,
  "brandColor": "#1b5e8c",
  "name": {
    "en": "Hagelschutz - einfach automatisch",
    "de": "Hagelschutz - einfach automatisch"
  },
  "description": {
    "en": "Hail protection for your blinds – automatic warning via REST API",
    "de": "Hagelschutz für Ihre Storen – automatische Warnung via REST API"
  },
  "category": [
    "security",
    "climate"
  ],
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png"
  },
  "author": {
    "name": "Andi",
    "email": "andi@wirzfamily.ch"
  },
  "flow": {
    "triggers": [
      {
        "id": "api_error",
        "title": {
          "en": "API connection failed",
          "de": "API-Verbindung fehlgeschlagen"
        },
        "titleFormatted": {
          "en": "API connection failed on [[device]]",
          "de": "API-Verbindung fehlgeschlagen auf [[device]]"
        },
        "hint": {
          "en": "Triggered when the API returns a non-200 status or times out.",
          "de": "Wird ausgelöst, wenn die API keinen HTTP 200 zurückgibt oder zeitüberschreitet."
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=hagelschutz"
          }
        ],
        "tokens": [
          {
            "name": "error",
            "type": "string",
            "title": {
              "en": "Error message",
              "de": "Fehlermeldung"
            },
            "example": "HTTP 503: Service Unavailable"
          }
        ]
      },
      {
        "id": "api_recovered",
        "title": {
          "en": "API connection recovered",
          "de": "API-Verbindung wiederhergestellt"
        },
        "titleFormatted": {
          "en": "API connection recovered on [[device]]",
          "de": "API-Verbindung wiederhergestellt auf [[device]]"
        },
        "hint": {
          "en": "Triggered when the API responds successfully again after an error.",
          "de": "Wird ausgelöst, wenn die API nach einem Fehler wieder erfolgreich antwortet."
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=hagelschutz"
          }
        ]
      },
      {
        "id": "hail_warning_active",
        "title": {
          "en": "Hail warning is active",
          "de": "Hagelwarnung ist aktiv"
        },
        "titleFormatted": {
          "en": "Hail warning is active on [[device]]",
          "de": "Hagelwarnung ist aktiv auf [[device]]"
        },
        "hint": {
          "en": "Triggered when a hail warning becomes active (currentState changes from 0 to 1 or 2).",
          "de": "Wird ausgelöst, wenn eine Hagelwarnung aktiv wird (currentState wechselt von 0 auf 1 oder 2)."
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=hagelschutz"
          }
        ],
        "tokens": [
          {
            "name": "signal",
            "type": "number",
            "title": {
              "en": "currentState",
              "de": "currentState"
            },
            "example": 1
          },
          {
            "name": "description",
            "type": "string",
            "title": {
              "en": "Description",
              "de": "Beschreibung"
            },
            "example": "Hail warning active"
          }
        ]
      },
      {
        "id": "hail_warning_cleared",
        "title": {
          "en": "Hail warning cleared",
          "de": "Hagelwarnung aufgehoben"
        },
        "titleFormatted": {
          "en": "Hail warning cleared on [[device]]",
          "de": "Hagelwarnung aufgehoben auf [[device]]"
        },
        "hint": {
          "en": "Triggered when a hail warning is no longer active (currentState returns to 0).",
          "de": "Wird ausgelöst, wenn eine Hagelwarnung nicht mehr aktiv ist (currentState kehrt zu 0 zurück)."
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=hagelschutz"
          }
        ]
      },
      {
        "id": "signal_changed",
        "title": {
          "en": "Signal value changed",
          "de": "Signalwert hat sich geändert"
        },
        "titleFormatted": {
          "en": "Signal value changed on [[device]]",
          "de": "Signalwert hat sich geändert auf [[device]]"
        },
        "hint": {
          "en": "Triggered on every change of currentState.",
          "de": "Wird bei jeder Änderung von currentState ausgelöst."
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=hagelschutz"
          }
        ],
        "tokens": [
          {
            "name": "signal",
            "type": "number",
            "title": {
              "en": "New currentState",
              "de": "Neuer currentState"
            },
            "example": 1
          }
        ]
      }
    ],
    "conditions": [
      {
        "id": "is_api_error",
        "title": {
          "en": "API connection !{{has failed|is working}}",
          "de": "API-Verbindung !{{ist fehlgeschlagen|funktioniert}}"
        },
        "titleFormatted": {
          "en": "API connection !{{has failed|is working}} on [[device]]",
          "de": "API-Verbindung !{{ist fehlgeschlagen|funktioniert}} auf [[device]]"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=hagelschutz"
          }
        ]
      },
      {
        "id": "is_hail_warning_active",
        "title": {
          "en": "Hail warning !{{is|is not}} active",
          "de": "Hagelwarnung !{{ist|ist nicht}} aktiv"
        },
        "titleFormatted": {
          "en": "Hail warning !{{is|is not}} active on [[device]]",
          "de": "Hagelwarnung !{{ist|ist nicht}} aktiv auf [[device]]"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=hagelschutz"
          }
        ]
      },
      {
        "id": "signal_level_is",
        "title": {
          "en": "currentState !{{is|is not}} {{level}}",
          "de": "currentState !{{ist|ist nicht}} {{level}}"
        },
        "titleFormatted": {
          "en": "currentState !{{is|is not}} [[level]]",
          "de": "currentState !{{ist|ist nicht}} [[level]]"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=hagelschutz"
          },
          {
            "name": "level",
            "type": "number",
            "title": {
              "en": "currentState (0 = no hail, 1 = hail, 2 = test alarm)",
              "de": "currentState (0 = kein Hagel, 1 = Hagel, 2 = Testalarm)"
            },
            "min": 0,
            "max": 2,
            "step": 1
          }
        ]
      }
    ],
    "actions": [
      {
        "id": "force_poll",
        "title": {
          "en": "Check hail status now",
          "de": "Hagelstatus jetzt prüfen"
        },
        "titleFormatted": {
          "en": "Check hail status now on [[device]]",
          "de": "Hagelstatus jetzt prüfen auf [[device]]"
        },
        "hint": {
          "en": "Immediately triggers an API poll without waiting for the next 120-second interval.",
          "de": "Löst sofort eine API-Abfrage aus, ohne das nächste 120-Sekunden-Intervall abzuwarten."
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=hagelschutz"
          }
        ]
      }
    ]
  },
  "drivers": [
    {
      "name": {
        "en": "Hail Warning Sensor",
        "de": "Hagelwarn-Sensor"
      },
      "class": "sensor",
      "capabilities": [
        "alarm_generic",
        "api_error_state",
        "hail_state"
      ],
      "capabilitiesOptions": {
        "alarm_generic": {
          "title": {
            "en": "Hail Warning",
            "de": "Hagelwarnung"
          }
        }
      },
      "images": {
        "small": "/drivers/hagelschutz/assets/images/small.png",
        "large": "/drivers/hagelschutz/assets/images/large.png"
      },
      "pair": [
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "settings": [
        {
          "type": "group",
          "label": {
            "en": "API Configuration",
            "de": "API-Konfiguration"
          },
          "children": [
            {
              "id": "device_id",
              "type": "text",
              "label": {
                "en": "Device ID (Serial Number)",
                "de": "Geräte-ID (Seriennummer / MAC-Adresse)"
              },
              "hint": {
                "en": "12-character serial number (MAC address of your Signalbox), provided after registration at meteo.netitservices.com",
                "de": "12-stellige Seriennummer (MAC-Adresse der Signalbox), erhalten nach Registrierung auf meteo.netitservices.com"
              },
              "value": ""
            },
            {
              "id": "hwtype_id",
              "type": "number",
              "label": {
                "en": "Hardware Type ID (hwtypeId)",
                "de": "Hardware-Typ-ID (hwtypeId)"
              },
              "hint": {
                "en": "Integer device type identifier provided at registration (see your registration confirmation).",
                "de": "Ganzzahliger Gerätetyp-Identifikator, erhalten bei der Registrierung (siehe Registrierungsbestätigung)."
              },
              "value": 1,
              "min": 1,
              "max": 9999,
              "step": 1
            }
          ]
        }
      ],
      "id": "hagelschutz"
    }
  ],
  "capabilities": {
    "api_error_state": {
      "type": "boolean",
      "title": {
        "en": "API Connection Error",
        "de": "API-Verbindungsfehler"
      },
      "desc": {
        "en": "True when the last API request failed (non-200 response or timeout).",
        "de": "Wahr, wenn die letzte API-Abfrage fehlgeschlagen ist (kein HTTP 200 oder Timeout)."
      },
      "uiComponent": "sensor",
      "uiQuickAction": false,
      "getable": true,
      "setable": false,
      "insights": true,
      "icon": "/drivers/hagelschutz/assets/icons/api_error_state.svg"
    },
    "hail_state": {
      "type": "number",
      "title": {
        "en": "Hail Signal (currentState)",
        "de": "Hagelsignal (currentState)"
      },
      "desc": {
        "en": "Current state from the hail warning API: 0 = no hail, 1 = hail, 2 = test alarm",
        "de": "Aktueller Status der Hagelwarn-API: 0 = kein Hagel, 1 = Hagel, 2 = Testalarm"
      },
      "uiComponent": "sensor",
      "uiQuickAction": false,
      "getable": true,
      "setable": false,
      "insights": true
    }
  }
}